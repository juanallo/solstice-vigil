{
  "name": "solstice-vigil",
  "version": "1.0.0",
  "description": "SOLSTICE VIGIL — a solo narrative RPG about holding the balance between day and night.",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test --project=unit",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "generate:d20": "node scripts/generate-d20-faces.mjs",
    "demo:final": "node demo-final/run.mjs",
    "demo:final:capture": "node demo-final/demo.mjs",
    "demo:final:render": "node demo-final/render.mjs",
    "demo:final:mobile": "node demo-final/run-mobile.mjs",
    "demo:final:mobile:capture": "node demo-final/demo-mobile.mjs",
    "demo:final:mobile:render": "node demo-final/render-mobile.mjs"
  },
  "keywords": [],
  "author": "Juan Manuel Allo Ron",
  "license": "MIT",
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "astro": "^5.16.6",
    "playwright": "^1.61.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  }
}
